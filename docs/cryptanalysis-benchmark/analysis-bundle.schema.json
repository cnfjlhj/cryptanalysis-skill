{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CryptanalysisAnalysisBundle",
  "type": "object",
  "required": [
    "source_items"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "state_hint": {
      "type": "string"
    },
    "paper": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "primitive": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "block_size_bits": {
          "type": "integer",
          "minimum": 1
        },
        "key_size_bits": {
          "type": "integer",
          "minimum": 1
        },
        "round_count_claimed": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "attack": {
      "type": "object",
      "properties": {
        "family": {
          "type": "string"
        },
        "difference_model": {
          "type": "string"
        },
        "claim_kind": {
          "type": "string"
        },
        "granularity": {
          "type": "string"
        },
        "exactness_goal": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "target": {
      "type": "object",
      "properties": {
        "case_id": {
          "type": "string"
        },
        "claim": {
          "type": "string"
        },
        "comparison_point": {
          "type": "string"
        },
        "round_end": {
          "type": "integer"
        },
        "sbox_model": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "lane": {
      "type": "object",
      "properties": {
        "sbox_model": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "source_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "uri": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

          "selector": {
            "round": 1,
            "bit_start": 0,
            "bit_end": 79
          },
          "relation": ">=",
          "value": 1,
          "rationale": "Appendix A.1 adds one more constraint to exclude the zero initial-key-difference case because that case belongs to the single-key model."
        }
      ],
      "emission_target_format": "lp",
      "output_capture": [
        {
          "field_id": "solver_status",
          "field_type": "string",

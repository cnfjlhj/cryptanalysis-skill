            "value_source": "expected_or_verified_lower_bound"
          }
        ],
        "notes": "This mirrors Appendix A.1 exactly: the 24-round claim is presented as a split-strategy upper bound derived from two 12-round lower bounds, not as a direct 24-round optimum characteristic search."
      },
      "output_capture": [
        {
          "field_id": "derived_bound",
          "field_type": "string",
          "required": true
        },
        {
          "field_id": "supporting_lower_bound_reference",

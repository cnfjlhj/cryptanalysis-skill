      },
      "depends_on_unit_ids": [
        "p1_compute_12r_lower_bound_model"
      ],
      "derivation": {
        "rule_id": "two_window_split_with_single_sbox_mdp",
        "expression": "(2^-2)^N12_window_1 * (2^-2)^N12_window_2 with N12_window_1 = 16 and N12_window_2 = 16",
        "input_bindings": [
          {
            "from_unit_id": "p1_compute_12r_lower_bound_model",
            "symbol": "N12_window_1",
            "value_source": "expected_or_verified_lower_bound"
          },
          {
            "from_unit_id": "p1_compute_12r_lower_bound_model",

        {
          "field_id": "lp_artifact_path",
          "field_type": "path",
          "required": false
        },
        {
          "field_id": "solver_log_path",
          "field_type": "path",
          "required": false
        }
      ],
      "expected_output": {
        "output_kind": "lower_bound",
        "symbolic_name": "N12_present80_related_key",
        "expected_value": 16,
        "paper_location": "Appendix A.1, Table 4 and the concluding paragraph immediately below it",
        "provenance": "solver_model"
      },
      "notes": "If a later emitter chooses to instantiate a different 12-round window, it must preserve the same structural scope and objective semantics."
    },
    {
      "unit_id": "p2_split_24r_upper_bound_derivation",
      "unit_kind": "derived_result",
      "phase_ref": "p2_split_24r_into_two_12r_windows",
      "round_scope": {
        "from_round": 1,
        "to_round": 24,

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LocalSemanticsRulePack",
  "type": "object",
  "required": [
    "rule_pack_id",
    "target_primitive_id",
    "source_refs",
    "component_scope",
    "property_domain",
    "variable_layout",
    "rule_groups"
  ],
  "properties": {
    "rule_pack_id": {
      "type": "string"
    },
    "target_primitive_id": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "label"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "attack_paper",
              "primitive_paper",
              "appendix",
              "code",
              "note"
            ]
          },
          "label": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "component_scope": {
      "type": "object",
      "required": [
        "operator_type",
        "component_name",
        "input_width_bits",
        "output_width_bits"
      ],
      "properties": {
        "operator_type": {
          "type": "string",
          "enum": [
            "sbox",
            "xor",
            "linear_layer",
            "permute_bits",
            "add_mod",
            "custom"
          ]
        },
        "component_name": {
          "type": "string"
        },
        "input_width_bits": {
          "type": "integer",
          "minimum": 1
        },
        "output_width_bits": {
          "type": "integer",
          "minimum": 1
        },
        "usage_notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "property_domain": {
      "type": "object",
      "required": [
        "semantic_domain",
        "granularity",
        "exactness"
      ],
      "properties": {
        "semantic_domain": {
          "type": "string",
          "enum": [
            "xor_differential",
            "linear_mask",
            "integral_property",
            "impossible_differential",
            "zero_correlation",
            "custom"
          ]
        },
        "granularity": {
          "type": "string",
          "enum": [
            "bit",
            "word",
            "cell",
            "mixed"
          ]
        },
        "exactness": {
          "type": "string",
          "enum": [
            "exact",
            "approximate",
            "valid_cutting_off",
            "upper_bound_support",
            "unknown"
          ]
        },
        "intended_backends": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "milp",
              "sat",
              "smt",
              "cp",
              "custom"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "resolver_metadata": {
      "type": "object",
      "required": [
        "rule_families"
      ],
      "properties": {
        "rule_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "component_name_aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "type": "integer"
        },
        "matching_notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "variable_layout": {
      "type": "object",
      "required": [
        "input_vars",
        "output_vars"
      ],
      "properties": {
        "input_vars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_vars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "indexing_notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "rule_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "group_id",
          "group_type",
          "purpose",
          "inequalities"
        ],
        "properties": {
          "group_id": {
            "type": "string"
          },
          "group_type": {
            "type": "string",
            "enum": [
              "logical_condition_cdp",
              "convex_hull_full",
              "convex_hull_selected",
              "custom"
            ]
          },
          "purpose": {
            "type": "string"
          },
          "selection_strategy": {
            "type": "string"
          },
          "removed_impossible_patterns_count": {
            "type": "integer",
            "minimum": 0
          },
          "inequalities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "label",
                "coefficients",
                "constant",
                "relation"
              ],
              "properties": {
                "label": {
                  "type": "string"
                },
                "coefficients": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "integer"
                  }
                },
                "constant": {
                  "type": "integer"
                },
                "relation": {
                  "type": "string",
                  "enum": [
                    ">=",
                    "<=",
                    "="
                  ]
                },
                "derivation": {
                  "type": "string"
                },
                "evidence": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
